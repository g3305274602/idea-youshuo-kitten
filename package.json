{
  "name": "youshuo",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm exec tsc -- -b && vite build",
    "format": "prettier . --write",
    "lint": "eslint . && prettier . --check",
    "preview": "vite preview",
    "test": "vitest run",
    "generate": "cargo run -p gen-bindings -- --out-dir src/module_bindings --module-path spacetimedb && prettier --write src/module_bindings",
    "spacetime:generate": "spacetime generate -y --lang typescript --out-dir src/module_bindings --module-path spacetimedb",
    "spacetime:publish:local": "spacetime publish -y --module-path spacetimedb --server local",
    "spacetime:publish": "spacetime publish -y --module-path spacetimedb --server maincloud",
    "spacetime:publish:break": "spacetime publish idea-jd2zx -y --module-path spacetimedb --server maincloud --delete-data=on-conflict",
    "spacetime:seed-demo": "spacetime call -y idea-jd2zx dev_seed_demo_users",
    "spacetime:seed-capsules": "node spacetimedb/scripts/run-seed-capsule-slots.mjs",
    "deploy:cloud": "npm run spacetime:generate && npm run spacetime:publish && npm run build",
    "email:gateway": "node email-gateway/server.mjs"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "spacetimedb": "^2.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^5.0.2",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.3.3",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^7.1.5",
    "vitest": "3.2.4"
  }
}
